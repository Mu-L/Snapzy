          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc571 \ucea1\ucc98"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0417\u0430\u0445\u0432\u0430\u0442 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ch\u1ee5p \u1ee9ng d\u1ee5ng"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5e94\u7528\u7a97\u53e3\u622a\u5c4f"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u61c9\u7528\u7a0b\u5f0f\u8996\u7a97\u622a\u5716"
          }
        }
      }
    },
    "preferences-shortcuts.application-recording-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einzeltaste (A) koppelt mit \u201eBildschirm aufzeichnen\u201c; Modifikator-Kombination (\u21e7\u2318A)\nfunktioniert unabh\u00e4ngig."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single key (A) pairs with Record Screen; modifier combo (\u21e7\u2318A)\nworks independently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La tecla \u00fanica (A) se empareja con Grabar pantalla; la combinaci\u00f3n de modificadores (\u21e7\u2318A)\nfunciona de forma independiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La touche unique (A) est associ\u00e9e \u00e0 Enregistrer l\u2019\u00e9cran ; la combinaison de modificateurs (\u21e7\u2318A)\nfonctionne ind\u00e9pendamment."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5358\u4e00\u30ad\u30fc\uff08A\uff09\u306f\u753b\u9762\u9332\u753b\u3068\u9023\u52d5\u3057\u307e\u3059\u3002\u4fee\u98fe\u30ad\u30fc\u306e\u7d44\u307f\u5408\u308f\u305b\uff08\u21e7\u2318A\uff09\u306f\n\u72ec\u7acb\u3057\u3066\u52d5\u4f5c\u3057\u307e\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub2e8\uc77c \ud0a4(A)\ub294 \ud654\uba74 \ub179\ud654\uc640 \uc9dd\uc744 \uc774\ub8f9\ub2c8\ub2e4. \uc870\ud569 \ud0a4(\u21e7\u2318A)\ub294\n\ub3c5\ub9bd\uc801\uc73c\ub85c \ub3d9\uc791\ud569\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041e\u0434\u0438\u043d\u043e\u0447\u043d\u0430\u044f \u043a\u043b\u0430\u0432\u0438\u0448\u0430 (A) \u0441\u043e\u0447\u0435\u0442\u0430\u0435\u0442\u0441\u044f \u0441 \u0437\u0430\u043f\u0438\u0441\u044c\u044e \u044d\u043a\u0440\u0430\u043d\u0430; \u043a\u043e\u043c\u0431\u0438\u043d\u0430\u0446\u0438\u044f \u043c\u043e\u0434\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440\u043e\u0432 (\u21e7\u2318A)\n\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ph\u00edm \u0111\u01a1n (A) \u0111i c\u00f9ng Ghi m\u00e0n h\u00ecnh; combo modifier (\u21e7\u2318A)\nch\u1ea1y \u0111\u1ed9c l\u1eadp."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5355\u952e (A) \u4e0e\u300c\u5f55\u5236\u5c4f\u5e55\u300d\u8054\u52a8\uff1b\u4fee\u9970\u952e\u7ec4\u5408 (\u21e7\u2318A)\n\u53ef\u72ec\u7acb\u4f7f\u7528\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u55ae\u9375 (A) \u8207\u300c\u9304\u88fd\u87a2\u5e55\u300d\u9023\u52d5\uff1b\u4fee\u98fe\u9375\u7d44\u5408 (\u21e7\u2318A)\n\u53ef\u7368\u7acb\u4f7f\u7528\u3002"
          }
        }
      }
    },
