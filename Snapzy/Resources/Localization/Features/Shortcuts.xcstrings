            "value": "Action Required"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acci\u00f3n requerida"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Action requise"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30a2\u30af\u30b7\u30e7\u30f3\u304c\u5fc5\u8981\u3067\u3059"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud544\uc694\ud55c \uc870\uce58"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "C\u1ea7n thao t\u00e1c"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u9700\u8981\u91c7\u53d6\u884c\u52a8"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u9700\u8981\u63a1\u53d6\u884c\u52d5"
          }
        }
      }
    },
    "preferences-shortcuts.annotate-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verkn\u00fcpfungen f\u00fcr allgemeine Aktionen im Anmerkungseditor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shortcuts for common actions inside the annotation editor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesos directos para acciones comunes dentro del editor de anotaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourcis pour les actions courantes dans l'\u00e9diteur d'annotations."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6ce8\u91c8\u30a8\u30c7\u30a3\u30bf\u5185\u306e\u4e00\u822c\u7684\u306a\u30a2\u30af\u30b7\u30e7\u30f3\u306e\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc8fc\uc11d \ud3b8\uc9d1\uae30 \ub0b4\uc758 \uc77c\ubc18\uc801\uc778 \uc791\uc5c5\uc5d0 \ub300\ud55c \ub2e8\ucd95\ud0a4\uc785\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u042f\u0440\u043b\u044b\u043a\u0438 \u0434\u043b\u044f \u043e\u0431\u0449\u0438\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0432 \u0440\u0435\u0434\u0430\u043a\u0442\u043e\u0440\u0435 \u0430\u043d\u043d\u043e\u0442\u0430\u0446\u0438\u0439."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ph\u00edm t\u1eaft cho c\u00e1c thao t\u00e1c ph\u1ed5 bi\u1ebfn b\u00ean trong tr\u00ecnh ch\u1ec9nh s\u1eeda Annotate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6807\u6ce8\u7f16\u8f91\u5668\u5185\u5e38\u7528\u64cd\u4f5c\u7684\u5feb\u6377\u952e\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6a19\u8a3b\u7de8\u8f2f\u5668\u4e2d\u5e38\u7528\u64cd\u4f5c\u7684\u5feb\u901f\u9375\u3002"
          }
        }
      }
    },
    "preferences-shortcuts.annotation-tool-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastenkombinationen zum Wechseln der Werkzeuge im Anmerkungseditor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single-key shortcuts for switching tools in the annotation editor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Atajos de una sola tecla para cambiar de herramienta en el editor de anotaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccourcis \u00e0 une seule touche pour changer d'outil dans l'\u00e9diteur d'annotations."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6ce8\u91c8\u30a8\u30c7\u30a3\u30bf\u30fc\u3067\u30c4\u30fc\u30eb\u3092\u5207\u308a\u66ff\u3048\u308b\u305f\u3081\u306e\u5358\u4e00\u30ad\u30fc\u306e\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc8fc\uc11d \ud3b8\uc9d1\uae30\uc5d0\uc11c \ub3c4\uad6c \uc804\ud658\uc744 \uc704\ud55c \ub2e8\uc77c \ud0a4 \ub2e8\ucd95\ud0a4\uc785\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041e\u0434\u043d\u043e\u043a\u043b\u0430\u0432\u0438\u0448\u043d\u044b\u0435 \u0441\u043e\u0447\u0435\u0442\u0430\u043d\u0438\u044f \u043a\u043b\u0430\u0432\u0438\u0448 \u0434\u043b\u044f \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u044f \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u043e\u0432 \u0432 \u0440\u0435\u0434\u0430\u043a\u0442\u043e\u0440\u0435 \u0430\u043d\u043d\u043e\u0442\u0430\u0446\u0438\u0439."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ph\u00edm t\u1eaft m\u1ed9t ph\u00edm \u0111\u1ec3 chuy\u1ec3n c\u00f4ng c\u1ee5 trong tr\u00ecnh ch\u1ec9nh s\u1eeda Annotate."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u7528\u4e8e\u5728\u6ce8\u91ca\u7f16\u8f91\u5668\u4e2d\u5207\u6362\u5de5\u5177\u7684\u5355\u952e\u5feb\u6377\u952e\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u7528\u65bc\u5728\u6ce8\u91cb\u7de8\u8f2f\u5668\u4e2d\u5207\u63db\u5de5\u5177\u7684\u55ae\u9375\u5feb\u6377\u9375\u3002"
          }
        }
      }
    },
    "preferences-shortcuts.application-capture-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Im Bereichsaufnahme-Overlay."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single key (A) pairs with Capture Area; modifier combo (\u21e7\u2318A)\nworks independently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dentro de la superposici\u00f3n de Captura de \u00c1rea."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dans la surcouche Capture de zone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u7bc4\u56f2\u30ad\u30e3\u30d7\u30c1\u30e3\u306e\u30aa\u30fc\u30d0\u30fc\u30ec\u30a4\u5185"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc601\uc5ed \ucea1\ucc98 \uc624\ubc84\ub808\uc774 \uc548\uc5d0\uc11c"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0412\u043d\u0443\u0442\u0440\u0438 \u043e\u0432\u0435\u0440\u043b\u0435\u044f \u0437\u0430\u0445\u0432\u0430\u0442\u0430 \u043e\u0431\u043b\u0430\u0441\u0442\u0438."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ph\u00edm \u0111\u01a1n (A) \u0111i c\u00f9ng Ch\u1ee5p v\u00f9ng; combo modifier (\u21e7\u2318A)\nch\u1ea1y \u0111\u1ed9c l\u1eadp."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5728\u533a\u57df\u622a\u5c4f\u53e0\u52a0\u5c42\u4e2d\u4f7f\u7528"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u65bc\u5340\u57df\u622a\u5716\u758a\u52a0\u5c64\u4e2d\u4f7f\u7528"
          }
        }
      }
    },
    "preferences-shortcuts.application-capture-title": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
