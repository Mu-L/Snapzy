    "preferences-shortcuts.no-conflicts-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "F\u00fcr die Snapzy-Verkn\u00fcpfungen, die Sie derzeit aktiviert haben, wurden keine \u00fcberlappenden macOS-Screenshot-Verkn\u00fcpfungen gefunden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No overlapping macOS screenshot shortcuts were found for the Snapzy shortcuts you currently have enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se encontraron atajos de captura de pantalla de macOS superpuestos para los atajos de Snapzy que tienes habilitados actualmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun raccourci de capture d'\u00e9cran macOS se chevauchant n'a \u00e9t\u00e9 trouv\u00e9 pour les raccourcis Snapzy que vous avez actuellement activ\u00e9s."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u73fe\u5728\u6709\u52b9\u306a Snapzy \u306e\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3068\u91cd\u8907\u3059\u308b macOS \u306e\u30b9\u30af\u30ea\u30fc\u30f3\u30b7\u30e7\u30c3\u30c8\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u306f\u898b\u3064\u304b\u308a\u307e\u305b\u3093\u3067\u3057\u305f\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud604\uc7ac \ud65c\uc131\ud654\ud55c Snapzy \ub2e8\ucd95\ud0a4\uc5d0 \ub300\ud574 \uacb9\uce58\ub294 macOS \uc2a4\ud06c\ub9b0\uc0f7 \ub2e8\ucd95\ud0a4\uac00 \ubc1c\uacac\ub418\uc9c0 \uc54a\uc558\uc2b5\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u0414\u043b\u044f \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044b\u0445 \u0432 \u0434\u0430\u043d\u043d\u044b\u0439 \u043c\u043e\u043c\u0435\u043d\u0442 \u044f\u0440\u043b\u044b\u043a\u043e\u0432 Snapzy \u043d\u0435 \u043e\u0431\u043d\u0430\u0440\u0443\u0436\u0435\u043d\u043e \u043f\u0435\u0440\u0435\u043a\u0440\u044b\u0432\u0430\u044e\u0449\u0438\u0445\u0441\u044f \u044f\u0440\u043b\u044b\u043a\u043e\u0432 \u0441\u043d\u0438\u043c\u043a\u043e\u0432 \u044d\u043a\u0440\u0430\u043d\u0430 macOS."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kh\u00f4ng t\u00ecm th\u1ea5y ph\u00edm t\u1eaft ch\u1ee5p m\u00e0n h\u00ecnh c\u1ee7a macOS b\u1ecb tr\u00f9ng v\u1edbi c\u00e1c ph\u00edm t\u1eaft Snapzy \u0111ang b\u1eadt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5bf9\u4e8e\u60a8\u5f53\u524d\u542f\u7528\u7684 Snapzy \u5feb\u6377\u65b9\u5f0f\uff0c\u6ca1\u6709\u627e\u5230\u91cd\u53e0\u7684 macOS \u5c4f\u5e55\u622a\u56fe\u5feb\u6377\u65b9\u5f0f\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c0d\u65bc\u60a8\u7576\u524d\u5553\u7528\u7684 Snapzy \u5feb\u6377\u65b9\u5f0f\uff0c\u6c92\u6709\u627e\u5230\u91cd\u758a\u7684 macOS \u87a2\u5e55\u622a\u5716\u5feb\u6377\u65b9\u5f0f\u3002"
          }
        }
      }
    },
