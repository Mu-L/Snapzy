    "preferences-shortcuts.single-key-hint": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie zum Aufzeichnen. Verwenden Sie w\u00e4hrend der Aufnahme die R\u00fccktaste oder die Zeilenumschaltung, um eine Verkn\u00fcpfung zu deaktivieren. Esc zum Abbrechen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click to record. Use Backspace/Delete while recording to clear keys. Use the row toggle to turn a shortcut off. Esc to cancel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haga clic para grabar. Utilice la tecla Retroceso mientras graba o cambie de fila para desactivar un acceso directo. Esc para cancelar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez pour enregistrer. Utilisez Retour arri\u00e8re pendant l'enregistrement ou la bascule de ligne pour d\u00e9sactiver un raccourci. Echap pour annuler."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30af\u30ea\u30c3\u30af\u3057\u3066\u8a18\u9332\u3057\u307e\u3059\u3002\u8a18\u9332\u4e2d\u306b Backspace \u3092\u62bc\u3059\u304b\u3001\u884c\u306e\u30c8\u30b0\u30eb\u3067\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3092\u30aa\u30d5\u306b\u3067\u304d\u307e\u3059\u3002Esc \u3067\u30ad\u30e3\u30f3\u30bb\u30eb\u3057\u307e\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub179\uc74c\ud558\ub824\uba74 \ud074\ub9ad\ud558\uc138\uc694. \ubc14\ub85c\uac00\uae30\ub97c \ub044\ub824\uba74 \ub179\uc74c \uc911\uc5d0 \ubc31\uc2a4\ud398\uc774\uc2a4\ub97c \uc0ac\uc6a9\ud558\uac70\ub098 \ud589 \ud1a0\uae00\uc744 \uc0ac\uc6a9\ud558\uc138\uc694. \ucde8\uc18c\ud558\ub824\uba74 Esc\ub97c \ub204\ub974\uc138\uc694."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041d\u0430\u0436\u043c\u0438\u0442\u0435, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u043f\u0438\u0441\u0430\u0442\u044c. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 Backspace \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0437\u0430\u043f\u0438\u0441\u0438 \u0438\u043b\u0438 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0430\u0442\u0435\u043b\u044c \u0441\u0442\u0440\u043e\u043a, \u0447\u0442\u043e\u0431\u044b \u043e\u0442\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u044f\u0440\u043b\u044b\u043a. Esc \u0434\u043b\u044f \u043e\u0442\u043c\u0435\u043d\u044b."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "B\u1ea5m \u0111\u1ec3 ghi. D\u00f9ng Backspace/Delete khi \u0111ang ghi \u0111\u1ec3 x\u00f3a ph\u00edm. D\u00f9ng c\u00f4ng t\u1eafc c\u1ee7a h\u00e0ng \u0111\u1ec3 t\u1eaft ph\u00edm t\u1eaft. Esc \u0111\u1ec3 h\u1ee7y."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5355\u51fb\u5373\u53ef\u5f55\u5236\u3002\u5f55\u5236\u65f6\u4f7f\u7528\u9000\u683c\u952e\u6216\u884c\u5207\u6362\u53ef\u5173\u95ed\u5feb\u6377\u65b9\u5f0f\u3002 Esc \u53d6\u6d88\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u55ae\u64ca\u5373\u53ef\u9304\u5236\u3002\u9304\u5236\u6642\u4f7f\u7528\u9000\u683c\u9375\u6216\u884c\u5207\u63db\u53ef\u95dc\u9589\u5feb\u6377\u65b9\u5f0f\u3002 Esc \u53d6\u6d88\u3002"
          }
        }
      }
    },
    "preferences-shortcuts.smart-element-capture-description": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Live-highlight an accessible UI element, then click to capture it"
          }
        }
      }
    },
    "preferences-shortcuts.system-conflict-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivieren Sie die \u00fcberlappenden macOS-Verkn\u00fcpfungen, um Konflikte mit den Snapzy-Verkn\u00fcpfungen zu vermeiden, die Sie aktiviert lassen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn off the overlapping macOS shortcuts to avoid conflicts with the Snapzy shortcuts you keep enabled."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactive los atajos de macOS superpuestos para evitar conflictos con los atajos de Snapzy que mantiene habilitados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "D\u00e9sactivez les raccourcis macOS qui se chevauchent pour \u00e9viter les conflits avec les raccourcis Snapzy que vous gardez activ\u00e9s."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6709\u52b9\u306b\u3057\u305f Snapzy \u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3068\u306e\u7af6\u5408\u3092\u907f\u3051\u308b\u306b\u306f\u3001\u91cd\u8907\u3059\u308b macOS \u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3092\u30aa\u30d5\u306b\u3057\u3066\u304f\u3060\u3055\u3044\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ud65c\uc131\ud654\ub41c Snapzy \ub2e8\ucd95\ud0a4\uc640\uc758 \ucda9\ub3cc\uc744 \ubc29\uc9c0\ud558\ub824\uba74 \uacb9\uce58\ub294 macOS \ub2e8\ucd95\ud0a4\ub97c \ub044\uc138\uc694."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041e\u0442\u043a\u043b\u044e\u0447\u0438\u0442\u0435 \u043f\u0435\u0440\u0435\u043a\u0440\u044b\u0432\u0430\u044e\u0449\u0438\u0435\u0441\u044f \u044f\u0440\u043b\u044b\u043a\u0438 macOS, \u0447\u0442\u043e\u0431\u044b \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044c \u043a\u043e\u043d\u0444\u043b\u0438\u043a\u0442\u043e\u0432 \u0441 \u044f\u0440\u043b\u044b\u043a\u0430\u043c\u0438 Snapzy, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u044b \u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442\u0435 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043d\u044b\u043c\u0438."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "T\u1eaft c\u00e1c ph\u00edm t\u1eaft macOS b\u1ecb tr\u00f9ng \u0111\u1ec3 tr\u00e1nh xung \u0111\u1ed9t v\u1edbi c\u00e1c ph\u00edm t\u1eaft Snapzy m\u00e0 b\u1ea1n mu\u1ed1n gi\u1eef b\u1eadt."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5173\u95ed\u91cd\u53e0\u7684 macOS \u5feb\u6377\u65b9\u5f0f\uff0c\u4ee5\u907f\u514d\u4e0e\u60a8\u4fdd\u6301\u542f\u7528\u7684 Snapzy \u5feb\u6377\u65b9\u5f0f\u53d1\u751f\u51b2\u7a81\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u95dc\u9589\u91cd\u758a\u7684 macOS \u5feb\u6377\u65b9\u5f0f\uff0c\u4ee5\u907f\u514d\u8207\u60a8\u4fdd\u6301\u5553\u7528\u7684 Snapzy \u5feb\u6377\u65b9\u5f0f\u767c\u751f\u885d\u7a81\u3002"
          }
        }
      }
    },
    "preferences-shortcuts.system-conflict-title": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS-Screenshot-Verkn\u00fcpfungen \u00fcberschneiden sich mit Snapzy"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS screenshot shortcuts overlap with Snapzy"
          }
        },
