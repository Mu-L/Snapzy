    "preferences-shortcuts.global-section-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie Tastaturk\u00fcrzel, um von \u00fcberall aus aufzunehmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use keyboard shortcuts to capture from anywhere."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice atajos de teclado para capturar desde cualquier lugar."
