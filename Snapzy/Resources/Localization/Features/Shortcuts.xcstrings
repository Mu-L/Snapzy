    "preferences-shortcuts.recorder-hint": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicken Sie auf eine Verkn\u00fcpfungsschaltfl\u00e4che, um neue Schl\u00fcssel aufzuzeichnen. Verwenden Sie die Zeilenumschaltung, um eine Verkn\u00fcpfung zu deaktivieren. Dr\u00fccken Sie Esc, um den Vorgang abzubrechen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Click a shortcut button to record new keys. Use Backspace/Delete while recording to clear keys. Use the row toggle to turn a shortcut off. Press Esc to cancel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Haga clic en un bot\u00f3n de acceso directo para registrar nuevas claves. Utilice el interruptor de fila para desactivar un acceso directo. Presione Esc para cancelar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cliquez sur un bouton de raccourci pour enregistrer de nouvelles cl\u00e9s. Utilisez la bascule de ligne pour d\u00e9sactiver un raccourci. Appuyez sur \u00c9chap pour annuler."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u30dc\u30bf\u30f3\u3092\u30af\u30ea\u30c3\u30af\u3057\u3066\u65b0\u3057\u3044\u30ad\u30fc\u3092\u8a18\u9332\u3057\u307e\u3059\u3002\u884c\u306e\u30c8\u30b0\u30eb\u3067\u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3092\u30aa\u30d5\u306b\u3067\u304d\u307e\u3059\u3002Esc \u3067\u30ad\u30e3\u30f3\u30bb\u30eb\u3057\u307e\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc0c8 \ud0a4\ub97c \uae30\ub85d\ud558\ub824\uba74 \ubc14\ub85c\uac00\uae30 \ubc84\ud2bc\uc744 \ud074\ub9ad\ud558\uc138\uc694. \ubc14\ub85c\uac00\uae30\ub97c \ub044\ub824\uba74 \ud589 \ud1a0\uae00\uc744 \uc0ac\uc6a9\ud558\uc138\uc694. \ucde8\uc18c\ud558\ub824\uba74 Esc\ub97c \ub204\ub974\uc138\uc694."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041d\u0430\u0436\u043c\u0438\u0442\u0435 \u043a\u043d\u043e\u043f\u043a\u0443 \u0431\u044b\u0441\u0442\u0440\u043e\u0433\u043e \u0434\u043e\u0441\u0442\u0443\u043f\u0430, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u043d\u043e\u0432\u044b\u0435 \u043a\u043b\u044e\u0447\u0438. \u0418\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439\u0442\u0435 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0430\u0442\u0435\u043b\u044c \u0441\u0442\u0440\u043e\u043a, \u0447\u0442\u043e\u0431\u044b \u043e\u0442\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u044f\u0440\u043b\u044b\u043a. \u041d\u0430\u0436\u043c\u0438\u0442\u0435 Esc \u0434\u043b\u044f \u043e\u0442\u043c\u0435\u043d\u044b."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nh\u1ea5n n\u00fat ph\u00edm t\u1eaft \u0111\u1ec3 ghi t\u1ed5 h\u1ee3p m\u1edbi. D\u00f9ng Backspace/Delete khi \u0111ang ghi \u0111\u1ec3 x\u00f3a ph\u00edm. D\u00f9ng c\u00f4ng t\u1eafc c\u1ee7a h\u00e0ng \u0111\u1ec3 t\u1eaft ph\u00edm t\u1eaft. Nh\u1ea5n Esc \u0111\u1ec3 h\u1ee7y."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u70b9\u51fb\u5feb\u6377\u952e\u6309\u94ae\u5f55\u5236\u65b0\u7684\u6309\u952e\u7ec4\u5408\u3002\u53ef\u901a\u8fc7\u884c\u5185\u5f00\u5173\u505c\u7528\u67d0\u9879\u5feb\u6377\u952e\uff0c\u6309 Esc \u53d6\u6d88\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6309\u4e00\u4e0b\u5feb\u901f\u9375\u6309\u9215\u4ee5\u8a2d\u5b9a\u65b0\u7684\u7d44\u5408\u9375\uff1b\u53ef\u7528\u5217\u5167\u958b\u95dc\u505c\u7528\u55ae\u4e00\u5feb\u901f\u9375\u3002\u6309 Esc \u53d6\u6d88\u3002"
          }
        }
      }
    },
