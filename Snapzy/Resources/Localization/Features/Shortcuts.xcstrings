    },
    "preferences-shortcuts.auto-redact-sensitive-data-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sensiblen Text lokal finden und bearbeitbare Weichzeichnungsanmerkungen hinzuf\u00fcgen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find sensitive text locally and add editable blur annotations"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscar texto confidencial localmente y agregar anotaciones de desenfoque editables"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rechercher localement du texte sensible et ajouter des annotations de flou modifiables"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30ed\u30fc\u30ab\u30eb\u3067\u6a5f\u5bc6\u30c6\u30ad\u30b9\u30c8\u3092\u691c\u7d22\u3057\u3001\u7de8\u96c6\u53ef\u80fd\u306a\u307c\u304b\u3057\u6ce8\u91c8\u3092\u8ffd\u52a0\u3057\u307e\u3059"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub85c\uceec\uc5d0\uc11c \ubbfc\uac10\ud55c \ud14d\uc2a4\ud2b8\ub97c \ucc3e\uc544 \ud3b8\uc9d1 \uac00\ub2a5\ud55c \ube14\ub7ec \uc8fc\uc11d\uc744 \ucd94\uac00\ud569\ub2c8\ub2e4"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041b\u043e\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u043f\u043e\u0438\u0441\u043a \u043a\u043e\u043d\u0444\u0438\u0434\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0442\u0435\u043a\u0441\u0442\u0430 \u0438 \u0434\u043e\u0431\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u0443\u0435\u043c\u044b\u0445 \u0440\u0430\u0437\u043c\u044b\u0442\u0438\u0439"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "T\u00ecm v\u0103n b\u1ea3n nh\u1ea1y c\u1ea3m c\u1ee5c b\u1ed9 v\u00e0 th\u00eam c\u00e1c ch\u00fa th\u00edch l\u00e0m m\u1edd c\u00f3 th\u1ec3 ch\u1ec9nh s\u1eeda"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
