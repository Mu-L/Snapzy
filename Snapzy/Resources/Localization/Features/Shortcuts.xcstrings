        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30ad\u30fc\u30dc\u30fc\u30c9 \u30b7\u30e7\u30fc\u30c8\u30ab\u30c3\u30c8\u3092\u4f7f\u7528\u3057\u3066\u3001\u3069\u3053\u304b\u3089\u3067\u3082\u30ad\u30e3\u30d7\u30c1\u30e3\u3067\u304d\u307e\u3059\u3002"
