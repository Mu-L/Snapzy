        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u30ab\u30fc\u30c9\u304c\u6307\u306b\u8ffd\u5f93\u3059\u308b\u304b\u3001\u9006\u65b9\u5411\u306b\u79fb\u52d5\u3059\u308b\u304b\u3092\u9078\u629e\u3057\u3066\u304f\u3060\u3055\u3044"
