    "preferences-quick-access.swipe-sensitivity-description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Passen Sie an, wie schnell die Karte Ihrer Trackpad-Wischbewegung folgt"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust how fast the card follows your trackpad swipe"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ajusta qu\u00e9 tan r\u00e1pido la tarjeta sigue tu gesto en el trackpad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ajustez la vitesse de suivi de la carte lors du balayage sur le trackpad"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u30c8\u30e9\u30c3\u30af\u30d1\u30c3\u30c9\u306e\u30b9\u30ef\u30a4\u30d7\u306b\u30ab\u30fc\u30c9\u304c\u8ffd\u5f93\u3059\u308b\u901f\u5ea6\u3092\u8abf\u6574"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\ud2b8\ub799\ud328\ub4dc \uc2a4\uc640\uc774\ud504\uc5d0 \uce74\ub4dc\uac00 \ub530\ub77c\uac00\ub294 \uc18d\ub3c4 \uc870\uc815"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u0442\u0435 \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u0440\u0435\u0430\u043a\u0446\u0438\u0438 \u043a\u0430\u0440\u0442\u043e\u0447\u043a\u0438 \u043d\u0430 \u0441\u0432\u0430\u0439\u043f \u043f\u043e \u0442\u0440\u0435\u043a\u043f\u0430\u0434\u0443"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u0110i\u1ec1u ch\u1ec9nh t\u1ed1c \u0111\u1ed9 th\u1ebb di chuy\u1ec3n theo c\u1eed ch\u1ec9 vu\u1ed1t tr\u00ean trackpad"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u8c03\u6574\u5361\u7247\u8ddf\u968f\u89e6\u63a7\u677f\u8f7b\u626b\u7684\u901f\u5ea6"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u8abf\u6574\u5361\u7247\u8ddf\u96a8\u89f8\u63a7\u677f\u6ed1\u52d5\u7684\u901f\u5ea6"
          }
        }
      }
    },
