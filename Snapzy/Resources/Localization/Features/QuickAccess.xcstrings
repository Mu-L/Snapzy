        },
        "ko": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\uce74\ub4dc\uac00 \uc190\uac00\ub77d\uc744 \ub530\ub97c\uc9c0 \ubc18\ub300 \ubc29\ud5a5\uc73c\ub85c \uc774\ub3d9\ud560\uc9c0 \uc120\ud0dd\ud558\uc138\uc694"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u0412\u044b\u0431\u0435\u0440\u0438\u0442\u0435, \u0441\u043b\u0435\u0434\u0443\u0435\u0442 \u043b\u0438 \u043a\u0430\u0440\u0442\u0430 \u0437\u0430 \u043f\u0430\u043b\u044c\u0446\u0435\u043c \u0438\u043b\u0438 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044f \u0432 \u043f\u0440\u043e\u0442\u0438\u0432\u043e\u043f\u043e\u043b\u043e\u0436\u043d\u043e\u043c \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0438"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ch\u1ecdn th\u1ebb di chuy\u1ec3n theo ng\u00f3n tay hay ng\u01b0\u1ee3c l\u1ea1i"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
            "value": "\u9009\u62e9\u5361\u7247\u662f\u8ddf\u968f\u624b\u6307\u79fb\u52a8\u8fd8\u662f\u5411\u76f8\u53cd\u65b9\u5411\u79fb\u52a8"
          }
