    "preferences-quick-access.pause-on-hover-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Countdown anhalten, wenn Sie mit der Maus \u00fcber die Karte fahren"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause countdown when hovering over the card"
          }
