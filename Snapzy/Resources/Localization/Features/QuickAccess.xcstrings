        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pausar la cuenta regresiva al pasar el cursor sobre la tarjeta"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mettre le compte \u00e0 rebours en pause lorsque vous survolez la carte"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30ab\u30fc\u30c9\u306b\u30db\u30d0\u30fc\u3057\u3066\u3044\u308b\u9593\u306f\u30ab\u30a6\u30f3\u30c8\u30c0\u30a6\u30f3\u3092\u4e00\u6642\u505c\u6b62"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uce74\ub4dc \uc704\ub85c \ub9c8\uc6b0\uc2a4\ub97c \uac00\uc838\uac00\uba74 \uce74\uc6b4\ud2b8\ub2e4\uc6b4\uc774 \uc77c\uc2dc \uc911\uc9c0\ub429\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041f\u0440\u0438\u043e\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0442\u044c \u043e\u0431\u0440\u0430\u0442\u043d\u044b\u0439 \u043e\u0442\u0441\u0447\u0435\u0442 \u043f\u0440\u0438 \u043d\u0430\u0432\u0435\u0434\u0435\u043d\u0438\u0438 \u043a\u0443\u0440\u0441\u043e\u0440\u0430 \u043d\u0430 \u043a\u0430\u0440\u0442\u043e\u0447\u043a\u0443"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "T\u1ea1m d\u1eebng \u0111\u1ebfm ng\u01b0\u1ee3c khi r\u00ea chu\u1ed9t l\u00ean th\u1ebb"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c06\u9f20\u6807\u60ac\u505c\u5728\u5361\u7247\u4e0a\u65f6\u6682\u505c\u5012\u8ba1\u65f6"
          }
