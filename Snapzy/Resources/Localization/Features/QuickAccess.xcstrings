    "preferences-quick-access.swipe-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen Sie Aktionen auf die kreisf\u00f6rmigen Wischziele, um auszuw\u00e4hlen, was nach einem Wischen mit zwei Fingern ausgef\u00fchrt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag actions onto the circular swipe targets to choose what runs after a two-finger swipe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra acciones a los objetivos de deslizamiento circulares para elegir qu\u00e9 se ejecuta despu\u00e9s de un deslizamiento con dos dedos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glissez des actions sur les cibles de balayage circulaires pour choisir ce qui s'ex\u00e9cute apr\u00e8s un balayage \u00e0 deux doigts."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5186\u5f62\u306e swipe \u30bf\u30fc\u30b2\u30c3\u30c8\u306b\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u30c9\u30e9\u30c3\u30b0\u3057\u3066\u30012\u672c\u6307\u3067\u30b9\u30ef\u30a4\u30d7\u3057\u305f\u5f8c\u306b\u5b9f\u884c\u3059\u308b\u64cd\u4f5c\u3092\u9078\u629e\u3057\u307e\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ub450 \uc190\uac00\ub77d \uc2a4\uc640\uc774\ud504 \ud6c4 \uc2e4\ud589\ud560 \uc791\uc5c5\uc744 \uc120\ud0dd\ud558\ub824\uba74 \uc6d0\ud615 \uc2a4\uc640\uc774\ud504 \ub300\uc0c1\uc73c\ub85c \uc791\uc5c5\uc744 \ub4dc\ub798\uadf8\ud558\uc138\uc694."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041f\u0435\u0440\u0435\u0442\u0430\u0449\u0438\u0442\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u043d\u0430 \u043a\u0440\u0443\u0433\u043b\u044b\u0435 \u0446\u0435\u043b\u0438 \u0434\u043b\u044f \u0441\u043c\u0430\u0445\u0438\u0432\u0430\u043d\u0438\u044f, \u0447\u0442\u043e\u0431\u044b \u0432\u044b\u0431\u0440\u0430\u0442\u044c, \u0447\u0442\u043e \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u043f\u0443\u0441\u043a\u0430\u0442\u044c\u0441\u044f \u043f\u043e\u0441\u043b\u0435 \u0441\u043c\u0430\u0445\u0438\u0432\u0430\u043d\u0438\u044f \u0434\u0432\u0443\u043c\u044f \u043f\u0430\u043b\u044c\u0446\u0430\u043c\u0438."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "K\u00e9o c\u00e1c h\u00e0nh \u0111\u1ed9ng v\u00e0o m\u1ee5c ti\u00eau vu\u1ed1t h\u00ecnh tr\u00f2n \u0111\u1ec3 ch\u1ecdn h\u00e0nh \u0111\u1ed9ng s\u1ebd ch\u1ea1y sau khi vu\u1ed1t b\u1eb1ng hai ng\u00f3n tay."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c06\u64cd\u4f5c\u62d6\u52a8\u5230\u5706\u5f62\u6ed1\u52a8\u76ee\u6807\u4e0a\uff0c\u4ee5\u9009\u62e9\u5728\u53cc\u6307\u8f7b\u626b\u540e\u8fd0\u884c\u4ec0\u4e48\u64cd\u4f5c\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c07\u64cd\u4f5c\u62d6\u79fb\u5230\u5713\u5f62\u6ed1\u52d5\u76ee\u6a19\u4e0a\uff0c\u4ee5\u9078\u64c7\u5728\u96d9\u6307\u8f15\u6383\u5f8c\u57f7\u884c\u4ec0\u9ebc\u64cd\u4f5c\u3002"
          }
        }
      }
    },
