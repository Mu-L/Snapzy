    "preferences-quick-access.trackpad-swipe-mode-description": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "W\u00e4hle, ob die Karte dem Finger folgt oder in die entgegengesetzte Richtung bewegt wird"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose whether the card follows your finger or moves in the opposite direction"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Elige si la tarjeta sigue tu dedo o se mueve en direcci\u00f3n opuesta"
