    "preferences-quick-access.quick-actions-description": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehe Listenzeilen, um das Kontextmen\u00fc neu anzuordnen. Ziehe Aktionen auf die Vorschau, um Kartenpositionen festzulegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag list rows to reorder the context menu. Drag actions onto the preview to set card positions."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastra las filas de la lista para reordenar el men\u00fa contextual. Arrastra acciones a la vista previa para definir posiciones en la tarjeta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser les lignes de la liste pour r\u00e9organiser le menu contextuel. Faites glisser des actions sur l\u2019aper\u00e7u pour d\u00e9finir les positions de la carte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u30ea\u30b9\u30c8\u306e\u884c\u3092\u30c9\u30e9\u30c3\u30b0\u3057\u3066\u30b3\u30f3\u30c6\u30ad\u30b9\u30c8\u30e1\u30cb\u30e5\u30fc\u3092\u4e26\u3079\u66ff\u3048\u307e\u3059\u3002\u30a2\u30af\u30b7\u30e7\u30f3\u3092\u30d7\u30ec\u30d3\u30e5\u30fc\u3078\u30c9\u30e9\u30c3\u30b0\u3057\u3066\u30ab\u30fc\u30c9\u4e0a\u306e\u4f4d\u7f6e\u3092\u8a2d\u5b9a\u3057\u307e\u3059\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\ubaa9\ub85d \ud589\uc744 \ub4dc\ub798\uadf8\ud574 \ucee8\ud14d\uc2a4\ud2b8 \uba54\ub274 \uc21c\uc11c\ub97c \ubc14\uafb8\uc138\uc694. \uc561\uc158\uc744 \ubbf8\ub9ac\ubcf4\uae30\ub85c \ub4dc\ub798\uadf8\ud574 \uce74\ub4dc \uc704\uce58\ub97c \uc124\uc815\ud558\uc138\uc694."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u041f\u0435\u0440\u0435\u0442\u0430\u0441\u043a\u0438\u0432\u0430\u0439\u0442\u0435 \u0441\u0442\u0440\u043e\u043a\u0438 \u0441\u043f\u0438\u0441\u043a\u0430, \u0447\u0442\u043e\u0431\u044b \u0438\u0437\u043c\u0435\u043d\u0438\u0442\u044c \u043f\u043e\u0440\u044f\u0434\u043e\u043a \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442\u043d\u043e\u0433\u043e \u043c\u0435\u043d\u044e. \u041f\u0435\u0440\u0435\u0442\u0430\u0441\u043a\u0438\u0432\u0430\u0439\u0442\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044f \u043d\u0430 \u043f\u0440\u0435\u0434\u043f\u0440\u043e\u0441\u043c\u043e\u0442\u0440, \u0447\u0442\u043e\u0431\u044b \u0437\u0430\u0434\u0430\u0442\u044c \u043f\u043e\u0437\u0438\u0446\u0438\u0438 \u043d\u0430 \u043a\u0430\u0440\u0442\u043e\u0447\u043a\u0435."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "K\u00e9o c\u00e1c d\u00f2ng trong danh s\u00e1ch \u0111\u1ec3 s\u1eafp x\u1ebfp l\u1ea1i menu ng\u1eef c\u1ea3nh. K\u00e9o thao t\u00e1c v\u00e0o b\u1ea3n xem tr\u01b0\u1edbc \u0111\u1ec3 \u0111\u1eb7t v\u1ecb tr\u00ed tr\u00ean th\u1ebb."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u62d6\u52a8\u5217\u8868\u884c\u4ee5\u91cd\u65b0\u6392\u5217\u4e0a\u4e0b\u6587\u83dc\u5355\u3002\u5c06\u64cd\u4f5c\u62d6\u5230\u9884\u89c8\u4e0a\u4ee5\u8bbe\u7f6e\u5361\u7247\u4f4d\u7f6e\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u62d6\u66f3\u5217\u8868\u5217\u4ee5\u91cd\u65b0\u6392\u5217\u5167\u5bb9\u9078\u55ae\u3002\u5c07\u52d5\u4f5c\u62d6\u5230\u9810\u89bd\u4e0a\u4ee5\u8a2d\u5b9a\u5361\u7247\u4f4d\u7f6e\u3002"
          }
        }
      }
    },
