    "app-identity.invalid-signature": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses App-Bundle besteht die Code-Signatur-Validierung von macOS nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app bundle does not pass macOS code-signature validation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este paquete de aplicaciones no pasa la validaci\u00f3n de firma de c\u00f3digo de macOS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet ensemble d'applications ne r\u00e9ussit pas la validation de signature de code macOS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "\u3053\u306e\u30a2\u30d7\u30ea \u30d0\u30f3\u30c9\u30eb\u306f macOS \u30b3\u30fc\u30c9\u7f72\u540d\u306e\u691c\u8a3c\u306b\u5408\u683c\u3057\u307e\u305b\u3093\u3002"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\uc774 \uc571 \ubc88\ub4e4\uc740 macOS \ucf54\ub4dc \uc11c\uba85 \uac80\uc99d\uc744 \ud1b5\uacfc\ud558\uc9c0 \ubabb\ud588\uc2b5\ub2c8\ub2e4."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "\u042d\u0442\u043e\u0442 \u043f\u0430\u043a\u0435\u0442 \u043f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u043d\u0435 \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0443 \u043f\u043e\u0434\u043f\u0438\u0441\u0438 \u043a\u043e\u0434\u0430 macOS."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "G\u00f3i \u1ee9ng d\u1ee5ng n\u00e0y kh\u00f4ng v\u01b0\u1ee3t qua ki\u1ec3m tra ch\u1eef k\u00fd m\u00e3 c\u1ee7a macOS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6b64\u5e94\u7528\u7a0b\u5e8f\u5305\u672a\u901a\u8fc7 macOS \u4ee3\u7801\u7b7e\u540d\u9a8c\u8bc1\u3002"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "\u6b64\u61c9\u7528\u7a0b\u5e8f\u5305\u672a\u901a\u904e macOS \u4ee3\u78bc\u7c3d\u540d\u9a57\u8b49\u3002"
          }
        }
      }
    },
    "app-identity.outside-applications": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installieren Sie Snapzy in /Applications, bevor Sie Berechtigungen erteilen. Aktueller Pfad: %@"
